# Root / shared
NODE_ENV=development

# Server
PORT=3000
CLIENT_URL=http://localhost:5173
CLIENT_URLS=http://localhost:5173

# Database — Neon/PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRY=15m

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/discord/callback

# Matchmaking tuning
MATCHMAKING_MATCH_SIZE=10
MATCHMAKING_MMR_TOLERANCE_BASE=500
MATCHMAKING_MMR_TOLERANCE_MAX=1200
MATCHMAKING_MMR_TOLERANCE_STEP=50
MATCHMAKING_MMR_TOLERANCE_STEP_MS=10000
MATCHMAKING_IGNORE_MMR_BALANCE=false

# Client / Vite
VITE_SOCKET_URL=
VITE_DISCORD_INVITE=
