# Root / shared
NODE_ENV=development

# Server
PORT=3000
# Fallback single frontend origin (legacy)
CLIENT_URL=http://localhost:5173
# Preferred allowlist (comma-separated). Put your public URL first.
CLIENT_URLS=http://localhost:5173,https://stormaxis-hots.pages.dev

# Database — Neon/PostgreSQL
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
DIRECT_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require
PRISMA_QUERY_LOGS=false

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRY=15m

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Local dev callback via Vite proxy. In production set this to https://YOUR-BACKEND.onrender.com/api/auth/discord/callback
DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/discord/callback

# Battle.net OAuth (identity linking; HOTS does not expose a public official profile API)
BNET_CLIENT_ID=
BNET_CLIENT_SECRET=
BNET_REGION=us
# Local dev callback via Vite proxy. In production set this to https://YOUR-BACKEND.onrender.com/api/auth/bnet/callback
BNET_REDIRECT_URI=http://localhost:5173/api/auth/bnet/callback
BNET_OAUTH_SCOPES=openid

# Discord Match Voice (optional, competitive rooms)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_STAFF_ROLE_ID=
DISCORD_MATCH_CATEGORY_PARENT_ID=
DISCORD_MATCH_CHANNEL_TTL_MINUTES=180

# Replay upload/parser (beta evidence)
# Local default is server/uploads/replays. In production use persistent storage before relying on uploaded files.
REPLAY_UPLOAD_DIR=
REPLAY_UPLOAD_MAX_BYTES=52428800

# Matchmaking tuning
MATCHMAKING_MATCH_SIZE=10
MATCHMAKING_MMR_TOLERANCE_BASE=500
MATCHMAKING_MMR_TOLERANCE_MAX=1200
MATCHMAKING_MMR_TOLERANCE_STEP=50
MATCHMAKING_MMR_TOLERANCE_STEP_MS=10000
MATCHMAKING_FORCE_RELAX_MMR_AFTER_MS=45000
MATCHMAKING_SMALL_POPULATION_QUEUE_LIMIT=20
MATCHMAKING_IGNORE_MMR_BALANCE=false

# Client / Vite
VITE_API_URL=
VITE_SOCKET_URL=
VITE_DISCORD_INVITE=
