generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")      // Pooled — para queries (PgBouncer de Neon)
  directUrl = env("DIRECT_URL")        // Directo — para migrations
}

// ─── Enums ───────────────────────────────────────────────

enum Role {
  USER
  MODERATOR
  ADMIN
  BANNED
}

enum MatchStatus {
  PENDING    // Esperando que los 10 acepten
  ACCEPTING  // Accept screen abierta
  VETOING    // Veto de mapas en curso
  PLAYING    // Partida en curso
  VOTING     // Votación de ganador abierta
  COMPLETED  // Partida finalizada
  CANCELLED  // Cancelada (alguien rechazó / timeout)
}

enum GameMode {
  COMPETITIVE
  UNRANKED
  TEAM
}

enum PlayerRole {
  RANGED
  HEALER
  OFFLANE
  FLEX
  TANK
}

enum ReplayUploadStatus {
  UPLOADED
  PARSED
  FAILED
}

enum TeamRole {
  OWNER
  CAPTAIN
  MEMBER
}

enum TeamCompetitiveRole {
  UNASSIGNED
  CAPTAIN
  STARTER
  SUBSTITUTE
  COACH
  STAFF
}

enum TeamStatus {
  ACTIVE
  ARCHIVED
}

enum TeamMemberStatus {
  ACTIVE
  INVITED
  LEFT
  KICKED
}

enum TeamInviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

enum TeamJoinRequestStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum ScrimSearchStatus {
  OPEN
  CHALLENGED
  MATCHED
  CANCELLED
  EXPIRED
}

enum ScrimChallengeStatus {
  PENDING
  ACCEPTED
  DECLINED
  CANCELLED
  EXPIRED
}

enum ScrimAccessRole {
  COACH
  OBSERVER
}

enum MatchOrigin {
  QUEUE
  SCRIM_SELF_SERVE
  SCRIM_ADMIN
}

// ─── Models ───────────────────────────────────────────────

model User {
  id       String @id @default(cuid())
  username String @unique
  email    String @unique
  password String? // null si solo tiene OAuth

  avatar   String?
  role     Role    @default(USER)

  // MMR / ELO
  mmr   Int    @default(1200)
  rank  String @default("LVL_7")
  wins  Int    @default(0)
  losses Int   @default(0)
  mainRole      PlayerRole?
  secondaryRole PlayerRole?
  countryCode   String? @db.VarChar(2)

  // OAuth IDs
  discordId String? @unique
  bnetId    String? @unique
  googleId  String? @unique

  // Metadata OAuth (para anti-smurfing)
  discordCreatedAt DateTime?
  discordUsername  String?
  bnetBattletag    String?

  // Anti-smurfing
  isBanned   Boolean  @default(false)
  isSuspect  Boolean  @default(false)
  isBot      Boolean  @default(false)
  banReason  String?
  bannedAt   DateTime?

  // Relations
  refreshTokens RefreshToken[]
  matchPlayers  MatchPlayer[]
  chatMessages  ChatMessage[]
  votes         Vote[]
  mvpVotesCast     MvpVote[] @relation("MvpVotesCast")
  mvpVotesReceived MvpVote[] @relation("MvpVotesReceived")
  matchMvps        Match[]   @relation("MatchMvp")
  replayUploads    MatchReplayUpload[] @relation("ReplayUploader")
  adminAuditLogsAuthored AdminAuditLog[] @relation("AdminAuditActor")
  adminAuditLogsTargeted AdminAuditLog[] @relation("AdminAuditTargetUser")
  ownedTeams Team[] @relation("TeamOwner")
  teamMemberships TeamMember[]
  teamInvitesSent TeamInvite[] @relation("TeamInviteSender")
  teamInvitesReceived TeamInvite[] @relation("TeamInviteRecipient")
  teamJoinRequestsSent TeamJoinRequest[] @relation("TeamJoinRequestSender")
  teamJoinRequestsReviewed TeamJoinRequest[] @relation("TeamJoinRequestReviewer")
  scrimSearchesCreated ScrimSearch[] @relation("ScrimSearchCreator")
  scrimAccesses ScrimAccess[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([mmr])
  @@index([rank])
  @@index([mainRole])
  @@index([secondaryRole])
  @@index([countryCode])
  @@index([isBot])
}

model Team {
  id      String @id @default(cuid())
  name    String @db.VarChar(80)
  slug    String @unique @db.VarChar(90)
  logoUrl String? @db.VarChar(500)
  bannerUrl String? @db.VarChar(500)
  description String? @db.VarChar(500)
  availabilityDays Json?
  status  TeamStatus @default(ACTIVE)

  ownerId String
  owner   User @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members TeamMember[]
  invites TeamInvite[]
  joinRequests TeamJoinRequest[]
  scrimSearches ScrimSearch[]
  challengesFrom ScrimChallenge[] @relation("ChallengeFromTeam")
  challengesTo ScrimChallenge[] @relation("ChallengeToTeam")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
  @@index([status, createdAt])
}

model TeamMember {
  id     String @id @default(cuid())
  teamId String
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  role   TeamRole @default(MEMBER)
  competitiveRole TeamCompetitiveRole @default(UNASSIGNED)
  status TeamMemberStatus @default(ACTIVE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([teamId, userId])
  @@index([userId, status])
  @@index([teamId, status])
  @@index([teamId, competitiveRole, status])
}

model TeamInvite {
  id     String @id @default(cuid())
  teamId String
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  invitedUserId String
  invitedUser   User @relation("TeamInviteRecipient", fields: [invitedUserId], references: [id], onDelete: Cascade)
  invitedById String
  invitedBy   User @relation("TeamInviteSender", fields: [invitedById], references: [id], onDelete: Cascade)

  status TeamInviteStatus @default(PENDING)
  respondedAt DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId, status])
  @@index([invitedUserId, status])
}

model TeamJoinRequest {
  id     String @id @default(cuid())
  teamId String
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation("TeamJoinRequestSender", fields: [userId], references: [id], onDelete: Cascade)
  reviewedById String?
  reviewedBy User? @relation("TeamJoinRequestReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  status TeamJoinRequestStatus @default(PENDING)
  respondedAt DateTime?
  expiresAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([teamId, status])
  @@index([userId, status])
}

model ScrimSearch {
  id String @id @default(cuid())

  teamId String
  team   Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User @relation("ScrimSearchCreator", fields: [createdById], references: [id], onDelete: Cascade)

  status ScrimSearchStatus @default(OPEN)
  starterUserIds Json
  coachUserId String?
  observerUserIds Json?
  notes String? @db.VarChar(500)

  outgoingChallenges ScrimChallenge[] @relation("ChallengeFromSearch")
  incomingChallenges ScrimChallenge[] @relation("ChallengeToSearch")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  expiresAt DateTime?

  @@index([teamId, status])
  @@index([status, createdAt])
}

model ScrimChallenge {
  id String @id @default(cuid())

  fromSearchId String
  fromSearch ScrimSearch @relation("ChallengeFromSearch", fields: [fromSearchId], references: [id], onDelete: Cascade)
  toSearchId String
  toSearch ScrimSearch @relation("ChallengeToSearch", fields: [toSearchId], references: [id], onDelete: Cascade)

  fromTeamId String
  fromTeam Team @relation("ChallengeFromTeam", fields: [fromTeamId], references: [id], onDelete: Cascade)
  toTeamId String
  toTeam Team @relation("ChallengeToTeam", fields: [toTeamId], references: [id], onDelete: Cascade)

  status ScrimChallengeStatus @default(PENDING)
  matchId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  respondedAt DateTime?

  @@unique([fromSearchId, toSearchId])
  @@index([toTeamId, status])
  @@index([fromTeamId, status])
}

model ScrimAccess {
  id String @id @default(cuid())
  matchId String
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  team Int
  role ScrimAccessRole

  createdAt DateTime @default(now())

  @@unique([matchId, userId])
  @@index([matchId, team])
  @@index([userId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  jti       String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([jti])
}

model Match {
  id     String      @id @default(cuid())
  status MatchStatus @default(PENDING)
  mode   GameMode    @default(COMPETITIVE)
  origin MatchOrigin @default(QUEUE)
  region String      @default("SA")

  // Post-veto
  selectedMap String?

  // Post-votación
  winner    Int? // 1 o 2 (team number)
  mvpUserId String?
  mvpUser   User? @relation("MatchMvp", fields: [mvpUserId], references: [id])
  duration  Int? // segundos estimados

  // Relations
  players  MatchPlayer[]
  vetoes   MapVeto[]
  messages ChatMessage[]
  votes    Vote[]
  mvpVotes MvpVote[]
  replayUploads MatchReplayUpload[]
  scrimDetails ScrimDetails?
  scrimAccesses ScrimAccess[]

  createdAt DateTime  @default(now())
  startedAt DateTime?
  endedAt   DateTime?

  @@index([status])
  @@index([mvpUserId])
  @@index([createdAt])
  @@index([origin, createdAt])
}


model ScrimDetails {
  id      String @id @default(cuid())
  matchId String @unique
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  team1Name String @db.VarChar(80)
  team2Name String @db.VarChar(80)
  notes     String? @db.VarChar(500)
  scheduledAt DateTime?
  createdById String?
  team1Id String?
  team2Id String?
  challengeId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([scheduledAt])
  @@index([createdById])
}

model MatchReplayUpload {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  uploadedById String?
  uploadedBy   User?   @relation("ReplayUploader", fields: [uploadedById], references: [id], onDelete: SetNull)

  status ReplayUploadStatus @default(UPLOADED)

  originalName String @db.VarChar(260)
  storagePath  String @db.VarChar(500)
  fileSize     Int
  sha256       String @unique @db.VarChar(64)

  parsedMap        String?
  parsedGameMode   String?
  parsedRegion     Int?
  parsedBuild      Int?
  parsedDuration   Int?
  parsedGameDate   DateTime?
  parsedWinnerTeam Int?
  parserStatus     String? @db.VarChar(64)
  parseError       String? @db.VarChar(500)
  parsedSummary    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([matchId, createdAt])
  @@index([uploadedById, createdAt])
  @@index([status, createdAt])
}

model MatchPlayer {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String?
  user    User?  @relation(fields: [userId], references: [id])
  isBot   Boolean @default(false)
  botName String?

  team      Int     // 1 o 2
  isCaptain Boolean @default(false)

  // ELO snapshot
  mmrBefore Int
  mmrAfter  Int?
  mmrDelta  Int?

  // Accept flow
  accepted Boolean? // null=pendiente, true=aceptó, false=rechazó

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([userId])
  @@index([isBot])
}

model MapVeto {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)

  mapId   String
  mapName String
  team    Int    // 1 o 2 — qué equipo vetó
  auto    Boolean @default(false) // true = auto-veto por timeout
  order   Int    // índice en la secuencia de vetos

  createdAt DateTime @default(now())

  @@index([matchId])
}

model Vote {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  winner Int // 1 o 2

  createdAt DateTime @default(now())

  @@unique([matchId, userId])
  @@index([matchId])
}

model MvpVote {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation("MvpVotesCast", fields: [userId], references: [id])
  nomineeUserId String
  nominee User @relation("MvpVotesReceived", fields: [nomineeUserId], references: [id])

  createdAt DateTime @default(now())

  @@unique([matchId, userId])
  @@index([matchId])
  @@index([nomineeUserId])
}

model ChatMessage {
  id      String @id @default(cuid())
  matchId String
  match   Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  content String @db.VarChar(500)
  channel String @default("GLOBAL") @db.VarChar(16)
  team    Int?

  createdAt DateTime @default(now())

  @@index([matchId, createdAt])
  @@index([matchId, channel, createdAt])
}

model AdminAuditLog {
  id String @id @default(cuid())

  actorId String?
  actor   User?   @relation("AdminAuditActor", fields: [actorId], references: [id], onDelete: SetNull)

  targetUserId String?
  targetUser   User?   @relation("AdminAuditTargetUser", fields: [targetUserId], references: [id], onDelete: SetNull)

  action     String @db.VarChar(64)
  entityType String @db.VarChar(32)
  entityId   String?
  summary    String @db.VarChar(280)
  metadata   Json?

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([action, createdAt])
  @@index([entityType, createdAt])
  @@index([actorId, createdAt])
  @@index([targetUserId, createdAt])
}
